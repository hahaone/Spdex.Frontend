map $http_x_forwarded_proto $spdex_forwarded_proto {
    default $http_x_forwarded_proto;
    ""      $scheme;
}

{% set spdex_web_node_header = web_node_id | default(inventory_hostname | regex_replace('^web', '')) %}
{% set spdex_web_release_header = web_release_sha | default(web_image_tag | default('unknown')) %}

server {
    listen {{ web_internal_api_listen }};
    server_name _;

    add_header X-SPdex-Web-Node "{{ spdex_web_node_header }}" always;
    add_header X-SPdex-Web-Release "{{ spdex_web_release_header }}" always;

    client_max_body_size 20m;

    location /api/ {
        proxy_pass {{ spdex_api_internal_url }};
        proxy_http_version 1.1;
        proxy_set_header Host {{ web_internal_api_host_header }};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $spdex_forwarded_proto;
        proxy_read_timeout 90s;
    }

    location / {
        return 404;
    }
}

server {
    listen 80 default_server;
    server_name _;

    add_header X-SPdex-Web-Node "{{ spdex_web_node_header }}" always;
    add_header X-SPdex-Web-Release "{{ spdex_web_release_header }}" always;

    location = {{ web_alb_health_path }} {
        access_log off;
        default_type text/plain;
        return 200 "ok\n";
    }

    location / {
        return 404;
    }
}

server {
    listen 80;
    server_name fjcx.spdex.com;

    add_header X-SPdex-Web-Node "{{ spdex_web_node_header }}" always;
    add_header X-SPdex-Web-Release "{{ spdex_web_release_header }}" always;

    client_max_body_size 20m;

    location = {{ web_alb_health_path }} {
        access_log off;
        default_type text/plain;
        return 200 "ok\n";
    }

    location /api/ {
        proxy_pass {{ spdex_api_internal_url }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Spdex-Frontend fjcx;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $spdex_forwarded_proto;
        proxy_read_timeout 90s;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $spdex_forwarded_proto;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 90s;
    }
}

