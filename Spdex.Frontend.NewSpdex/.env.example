NUXT_PUBLIC_API_BASE=http://localhost:5010
NUXT_PUBLIC_MOCK_MODE=true

# 阿里云验证码2.0（默认关闭）。开启需与后端 appsettings 的 Captcha:Enabled 同时打开。
# SceneId / prefix 来自阿里云验证码控制台创建的场景（非机密，前端用）。
NUXT_PUBLIC_CAPTCHA_ENABLED=false
NUXT_PUBLIC_CAPTCHA_SCENE_ID=
NUXT_PUBLIC_CAPTCHA_PREFIX=
NUXT_PUBLIC_CAPTCHA_REGION=cn
